{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A product in the store",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "badge": { "type": "string" },
        "soldOut": { "type": "boolean" },
        "img1": { "type": "string" },
        "img2": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "alt": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "price", "category", "soldOut", "img1", "img2", "alt", "description"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "orderNumber": { "type": "string" },
        "userId": { "type": "string" },
        "customer": {
          "type": "object",
          "properties": {
            "firstName": { "type": "string" },
            "lastName": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "gov": { "type": "string" },
            "address": { "type": "string" }
          },
          "required": ["firstName", "lastName", "phone", "gov", "address"]
        },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "couponCode": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderNumber", "customer", "items", "subtotal", "discount", "total", "status", "createdAt"]
    },
    "Wishlist": {
      "title": "Wishlist",
      "description": "A user's wishlist",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "number" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "updatedAt"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A promotional coupon code",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["percentage", "fixed"] },
        "value": { "type": "number" },
        "active": { "type": "boolean" },
        "usageCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "type", "value", "active", "usageCount", "createdAt"]
    },
    "Newsletter": {
      "title": "Newsletter",
      "description": "Newsletter subscription",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Blog": {
      "title": "Blog",
      "description": "A blog post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "published": { "type": "boolean" }
      },
      "required": ["id", "title", "slug", "content", "date", "published"]
    }
  },
  "firestore": {
    "users": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "products": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Store products"
    },
    "orders": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders"
    },
    "wishlists": {
      "schema": { "$ref": "#/entities/Wishlist" },
      "description": "User wishlists"
    },
    "coupons": {
      "schema": { "$ref": "#/entities/Coupon" },
      "description": "Promotional coupons"
    },
    "newsletters": {
      "schema": { "$ref": "#/entities/Newsletter" },
      "description": "Newsletter subscriptions"
    },
    "blogs": {
      "schema": { "$ref": "#/entities/Blog" },
      "description": "Blog posts"
    }
  }
}
